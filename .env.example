ENV=production

# OpenRouter LLM API key
OPENROUTER_API_KEY=sk-or-v1-your_key_here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Model to use via OpenRouter
MODEL_NAME=qwen/qwen3-next-80b-a3b-instruct

# Shared secret between Rails and Python service (must match Rails SERVICE_API_KEY)
# Generate with: openssl rand -hex 32
SERVICE_API_KEY=YOUR_STRONG_RANDOM_SERVICE_KEY_HERE

# Qdrant Cloud
QDRANT_API_KEY=your_qdrant_api_key
QDRANT_URL=https://your-instance.qdrant.io

# HuggingFace token (for model download, optional for public models)
HF_TOKEN=hf_your_token_here

# Redis (set by docker-compose via environment block; override here if needed)
# REDIS_HOST=redis
# REDIS_PORT=6379

# RAG tuning (optional — these are the defaults)
# SIMILARITY_THRESHOLD=0.30
# MAX_CONTEXT_LENGTH=2500
# CHUNK_SIZE=800
# CHUNK_OVERLAP=150
